{
  "name": "@craft-agent/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --go",
    "start:go": "expo start --go",
    "start:tunnel": "expo start --go --tunnel",
    "start:dev-client": "expo start",
    "start:dev-client:tunnel": "expo start --tunnel",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "doctor": "expo-doctor",
    "eas:build:ios:dev": "eas build --platform ios --profile development",
    "eas:build:ios:preview": "eas build --platform ios --profile preview",
    "eas:build:ios:production": "eas build --platform ios --profile production",
    "eas:update:preview": "eas update --branch preview",
    "eas:update:production": "eas update --branch production",
    "test": "jest",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@craft-agent/mobile-contracts": "workspace:*",
    "@craft-agent/mobile-tokens": "workspace:*",
    "expo": "^55.0.0",
    "expo-dev-client": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-updates": "~55.0.12",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sse": "^1.2.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "typescript": "^5.9.2"
  }
}
